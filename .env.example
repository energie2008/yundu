# ============================================
# Airport Panel - Environment Configuration
# Copy this file to .env and fill in values
# ============================================

# ---------- Application ----------
APP_ENV=development
APP_LOG_LEVEL=debug

# ---------- Database (PostgreSQL 16) ----------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=airport
POSTGRES_SSLMODE=disable
POSTGRES_DSN=postgres://app:app@localhost:5432/airport?sslmode=disable

# ---------- Redis ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ---------- NATS (optional) ----------
NATS_URL=nats://localhost:4222
NATS_PORT=4222

# ---------- MinIO (optional, S3-compatible storage) ----------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET=airport
MINIO_PORT=9000

# ---------- JWT / Auth ----------
# IMPORTANT: generate real secrets before production deployment!
#   go run ./cmd/genkey
# Or individually:
#   openssl rand -hex 32
JWT_SECRET=CHANGE_ME_RUN_genkey
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800
ARGON2_SALT=CHANGE_ME_RUN_genkey

# ---------- HMAC (request signing) ----------
HMAC_SECRET=CHANGE_ME_RUN_genkey

# ---------- Agent ----------
AGENT_API_TOKEN_SALT=CHANGE_ME_RUN_genkey

# ---------- CORS ----------
# Comma-separated list of allowed origins, use * for all
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# ---------- Service Ports ----------
API_GATEWAY_PORT=8080
IDENTITY_SERVICE_PORT=8081
NODE_SERVICE_PORT=8082
SUBSCRIPTION_SERVICE_PORT=8083
TRAFFIC_SERVICE_PORT=8084
ADMIN_WEB_PORT=5173
USER_WEB_PORT=5174

# ---------- Service Addresses (for api-gateway local dev) ----------
IDENTITY_SERVICE_ADDR=localhost:8081
NODE_SERVICE_ADDR=localhost:8082
SUBSCRIPTION_SERVICE_ADDR=localhost:8083
TRAFFIC_SERVICE_ADDR=localhost:8084

# ---------- Frontend ----------
VITE_API_BASE_URL=http://localhost:8080/api/v1

# ---------- Email (SMTP) ----------
# SMTP email sending configuration (configured via admin panel system settings)
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
MAIL_BASE_URL=http://localhost:5174

# ---------- Payment (TRC20/USDT) ----------
# TRON TRC20 USDT payment configuration (configured via admin panel system settings)
TRC20_ADDRESS=
TRONGRID_API=https://api.trongrid.io
TRONGRID_API_KEY=

# ---------- Subscription ----------
# Public-facing base URL for subscription links
SUB_BASE_URL=http://localhost:8080

# ---------- AI 诊断 (DeepSeek，优先使用) ----------
# DeepSeek API（OpenAI 兼容格式），配置后优先于 GLM 使用
# 文档: https://api-docs.deepseek.com/
LLM_DEEPSEEK_API_KEY=
LLM_DEEPSEEK_BASE_URL=https://api.deepseek.com
LLM_DEEPSEEK_MODEL=deepseek-chat

# ---------- AI 诊断 (GLM，备用) ----------
# 智谱 GLM 配置，DeepSeek 未配置时使用
LLM_GLM_API_KEY=
LLM_GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_GLM_MODEL=glm-4-flash

# ---------- Observability (Prometheus + Grafana + Loki + OTel) ----------
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
LOKI_PORT=3100
OTEL_COLLECTOR_PORT=4317

# OpenTelemetry exporter endpoint (otlp gRPC)
# Set to http://otel-collector:4317 in Docker, or http://localhost:4317 for local dev
OTEL_EXPORTER=none
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=node-service

# ---------- ACME (Let's Encrypt / ZeroSSL) ----------
# Email for ACME account registration (required for auto-cert renewal)
ACME_EMAIL=admin@example.com
# Directory URL: https://acme-v02.api.letsencrypt.org/directory (production)
#               https://acme-staging-v02.api.letsencrypt.org/directory (staging)
ACME_DIR_URL=https://acme-staging-v02.api.letsencrypt.org/directory
# Challenge type: http-01 or dns-01
ACME_CHALLENGE_TYPE=http-01
# DNS provider (for dns-01 challenge, e.g. cloudflare, alidns)
ACME_DNS_PROVIDER=

# ---------- HTTPS Ingress (Caddy) ----------
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443
# Domains for auto-TLS (comma-separated)
CADDY_DOMAIN_ADMIN=admin.example.com
CADDY_DOMAIN_USER=user.example.com
CADDY_DOMAIN_API=api.example.com