# ============================================
# YunDu .gitignore（物理隔离后的简化版）
# 目录已干净，仅需排除编译产物和敏感配置
# ============================================

# --- 二进制文件 ---
*.exe
*.dll
*.so
*.dylib
*.gz
*.zip
*.tar.gz
*.rar
*.7z

# --- 无扩展名二进制（按文件名排除）---
/node-agent
/node-agent-*
/node-service
/node-service-*
/api-gateway
/api-gateway-*
/identity-service
/identity-service-*
/subscription-service
/subscription-service-*
/traffic-service
/traffic-service-*
/migrate
/genkey
/statsprobe
/yunductl

# --- 编译产物目录 ---
**/bin/
**/dist/
**/target/
**/build/
**/out/
**/node_modules/

# --- 敏感配置 ---
.env
.env.*
!.env.example

# --- 日志 ---
*.log
**/logs/

# --- 临时文件 ---
**/tmp/
*.tmp
*.bak
*.pid
*.seed

# --- 前端构建产物 ---
*.tsbuildinfo

# --- Go ---
vendor/
*.test
*.out

# --- Coverage ---
coverage/
*.lcov
.nyc_output/

# --- IDE / OS ---
.idea/
.vscode/
.vs/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
